# 이 파일을 terraform.tfvars 로 복사 후 값 채우기.
# terraform.tfvars 는 .gitignore 에 반드시 포함.

region      = "ap-northeast-2"
environment = "prod"
project     = "lms"

# 본인 공인 IP(/32). `curl ifconfig.me` 로 확인 후 입력.
ssh_allowed_cidr = "203.0.113.45/32"

# `ssh-keygen -t ed25519 -f ~/.ssh/lms_ed25519` 생성 후 .pub 내용 그대로 붙여넣기.
ssh_public_key = "ssh-ed25519 AAAA... you@host"

# `openssl rand -base64 24` 로 생성.
db_password = "CHANGE_ME_STRONG_PASSWORD"

monthly_budget_usd        = 35
budget_notification_email = "you@example.com"
