# ==========================================================
# deploy/.env.example → EC2에서 /opt/lms/.env 로 복사 후 값 채우기
# 권한: chmod 600 /opt/lms/.env
# ==========================================================

# ----- 도메인 / TLS -----
DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# ----- Docker 이미지 태그 -----
# GitHub Actions deploy.yml 이 갱신함. 수동 배포 시 직접 지정.
APP_IMAGE=ghcr.io/your-gh-user/license-management-service:latest

# ----- MySQL (RDS 엔드포인트) -----
DB_HOST=lms-mysql.xxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=lms
DB_USERNAME=lmsadmin
DB_PASSWORD=CHANGE_ME

# ----- JWT -----
# 256bit 이상 랜덤값: `openssl rand -base64 48`
JWT_SECRET_KEY=CHANGE_ME

# ----- OAuth -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 프론트(Vercel) 도메인으로 설정. application.yaml 의 기본값(localhost)을 덮어씀.
OAUTH_GOOGLE_REDIRECT_URI=https://app.example.com/login/oauth2/google/callback
OAUTH_GITHUB_REDIRECT_URI=https://app.example.com/login/oauth2/github/callback
OAUTH_NAVER_REDIRECT_URI=https://app.example.com/login/oauth2/naver/callback

# ----- 백업 -----
AWS_REGION=ap-northeast-2
BACKUP_BUCKET=lms-backup-CHANGE_ME
# `openssl rand -base64 32`
BACKUP_GPG_PASSPHRASE=CHANGE_ME
